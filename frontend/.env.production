# Production build defaults
# Vite inlines these at build time. The runtime code in services/api.ts
# and services/websocket.ts uses these as the first preference.
#
# If you deploy the SPA behind a different hostname (e.g. ngrok, Cloudflare
# Pages, etc.), update VITE_PUBLIC_BASE_URL to match.

# Public origin (used by both axios and WebSocket). The Cloudflare
# tunnel at rpg.kitahim.uk terminates TLS and forwards to the local
# backend on port 8000.
VITE_PUBLIC_BASE_URL=https://rpg.kitahim.uk

# API and WebSocket base URLs. Default to same origin so requests
# stay on the same host (no CORS dance, no mixed content).
VITE_API_BASE_URL=https://rpg.kitahim.uk
VITE_WS_BASE_URL=wss://rpg.kitahim.uk
