# =============================================================================
# Backend environment variables — example template
# =============================================================================
# Copy this file to `.env` on each deployment host and fill in real values.
# `.env` is in .gitignore (committing real secrets is a security incident).
#
# This file is committed as a template. The actual `.env` is per-host:
#
#   Windows (BAZOOKA production):
#     copy backend\.env.example backend\.env
#     notepad backend\.env     # fill in POSTGRES_PASSWORD etc.
#
#   Linux (staging / dev):
#     cp backend/.env.example backend/.env
#     vim backend/.env
#
# The Pydantic Settings class (see backend/config.py) reads these on
# import. Defaults shown here are the local-dev defaults baked into
# config.py; if a value is not set here, Settings() falls back to the
# Pydantic default (which is fine for local dev but NOT for BAZOOKA
# production — you must at minimum set POSTGRES_PASSWORD and
# SECRET_KEY).


# =============================================================================
# Cloudflare (Phase L2 — named tunnel setup)
# =============================================================================
# Used by scripts\setup_named_tunnel.ps1 to create the DNS CNAME
# record for rpg.kitahim.uk -> <tunnel-uuid>.cfargotunnel.com
# (and to install the tunnel as a Windows service).
#
# To create the token:
#   1. Go to https://dash.cloudflare.com/profile/api-tokens
#   2. Create Token -> Edit Custom Token
#   3. Permissions:
#      - Zone:DNS:Edit                    (scoped to kitahim.uk zone)
#      - Account:Cloudflare Tunnel:Edit   (account-wide)
#   4. Zone Resources: Include -> Specific zone -> kitahim.uk
#   5. Continue to summary -> Create Token
#   6. Copy and paste below.
#
# Leave empty if you only use the Quick Tunnel (scripts\setup_cloudflared.ps1)
# — that script doesn't need a token.
CLOUDFLARE_API_TOKEN=


# =============================================================================
# Deployment: BAZOOKA-only (per MEMORY.md "Sandbox RPG 部署範圍
# 2026-06-07"). There is no Pi5 / cloud / Vercel deployment target.
# =============================================================================


# =============================================================================
# Database (Postgres 15+)
# =============================================================================
# Settings class reads these as POSTGRES_HOST, POSTGRES_PORT, etc.
# On BAZOOKA, this should point at a local Postgres installed via
# winget or Docker (see docs/DEPLOYMENT_BAZOOKA.md, Phase L1).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sandbox_rpg
POSTGRES_USER=rpg_user
# CHANGE ME — generate a strong password, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=change_me_in_production


# =============================================================================
# Backend server
# =============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=INFO


# =============================================================================
# Authentication (JWT)
# =============================================================================
# CHANGE ME — JWT secret key. Must be a long random string.
# Never reuse across environments. Rotate if compromised.
SECRET_KEY=change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24


# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================
# Comma-separated list of allowed origins. On BAZOOKA local-only
# deployment, this should include the frontend URL (e.g. the nginx
# reverse proxy on port 8077, or the Vite dev server on 5173).
#
# Pydantic reads this as a JSON list, not comma-separated. So the
# format is:
#   CORS_ORIGINS=["http://localhost:5173","http://BAZOOKA:8077"]
# For multiple origins on BAZOOKA LAN:
#   CORS_ORIGINS=["http://localhost:5173","http://192.168.0.50:8077"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]


# =============================================================================
# LLM — Cloud provider (MiniMax-M3 by default)
# =============================================================================
# Used as the narrative generation primary or fallback path.
# On BAZOOKA with internet access: set LLM_CLOUD_API_KEY.
# On offline-only BAZOOKA: leave LLM_CLOUD_API_KEY empty and the
# local R1 model (LM Studio) is the only path.
LLM_CLOUD_PROVIDER=minimax
LLM_CLOUD_API_KEY=
LLM_CLOUD_BASE_URL=https://api.minimax.chat/v1
LLM_CLOUD_MODEL=MiniMax-M3
LLM_CLOUD_TEMPERATURE=1.0
LLM_CLOUD_TOP_P=0.95
LLM_CLOUD_MAX_TOKENS=4000
LLM_CLOUD_TIMEOUT_SECONDS=60


# =============================================================================
# LLM — Local model (LM Studio, R1-14B)
# =============================================================================
# LM Studio runs the OpenAI-compatible API on http://127.0.0.1:1234/v1.
# The default model is qwen2.5-14b-instruct, but Phase D6+ uses
# deepseek-r1-distill-qwen-14b for the audit-hook skill.
#
# On BAZOOKA: start LM Studio manually once, then it stays running.
# To enable the R1 audit path, also set R1_BASE_URL and R1_MODEL
# at the bottom of this file.
LLM_LOCAL_ENABLED=true
LLM_LOCAL_BASE_URL=http://127.0.0.1:1234/v1
LLM_LOCAL_MODEL=qwen2.5-14b-instruct
LLM_LOCAL_TEMPERATURE=0.9
LLM_LOCAL_TOP_P=0.9
LLM_LOCAL_MAX_TOKENS=2000
LLM_LOCAL_TIMEOUT_SECONDS=120


# =============================================================================
# R1 audit client (separate from the narrative LLM)
# =============================================================================
# Used by backend/r1_audit_client.py. Reads via os.getenv(), not via
# the Settings class, so these are independent of the LLM_*_ vars.
# On BAZOOKA: defaults are fine (LM Studio + R1-14B model).
R1_BASE_URL=http://127.0.0.1:1234/v1
R1_MODEL=deepseek-r1-distill-qwen-14b


# =============================================================================
# Game settings
# =============================================================================
ROUND_DURATION_MINUTES=15
DAILY_ETL_HOUR=0
DAILY_ETL_MINUTE=0
WORLD_PARAMETER_FLUCTUATION_LIMIT=0.15
MAX_TAGS_PER_CHARACTER=8
MAX_SHIFT_PER_SEMANTIC_LEVEL=1


# =============================================================================
# LanceDB (vector store for world lore / memory palace)
# =============================================================================
# On BAZOOKA: use a stable directory on a non-system drive if possible.
# Example: LANCEDB_URI=C:\lancedb_data
# The default ./lancedb_data is relative to where uvicorn is launched
# from, which is fragile when running as a Windows service.
LANCEDB_URI=./lancedb_data
LANCEDB_TABLE_NAME=world_lore


# =============================================================================
# Embedding model (used by LanceDB)
# =============================================================================
# On BAZOOKA, LM Studio can serve nomic-embed-text-v1.5 via its
# embeddings endpoint. Default points at the same local server as
# the LLM (port 1234).
EMBEDDING_MODEL=nomic-embed-text-v1.5
EMBEDDING_DIM=768
EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1


# =============================================================================
# Development flags
# =============================================================================
# Set to true ONLY for local debugging. MUST be false in BAZOOKA prod.
DEBUG=false
# /docs (Swagger UI) — disable in prod if you don't want the public
# to see the API schema.
ENABLE_API_DOCS=true


# =============================================================================
# DEMO_MODE (not in Settings class, read directly via os.getenv)
# =============================================================================
# Set to "true" for zero-infrastructure demo (skips Postgres init,
# uses canned scenes_demo.py data). Set to "false" or leave empty
# for full production mode (requires Postgres + LanceDB + LM Studio).
#
#   DEMO_MODE=true uvicorn backend.main:app    # zero infra
#   DEMO_MODE=false uvicorn backend.main:app   # full production
#
# On BAZOOKA production: DEMO_MODE=false (or unset).
# On first-time local testing: DEMO_MODE=true to validate the
# installation before wiring up Postgres.
DEMO_MODE=false
