{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw-sandbox-rpg.dev/schemas/player_input.json",
  "title": "Player Input",
  "description": "Player submission for each game round",
  "type": "object",
  "properties": {
    "round": {
      "type": "integer",
      "minimum": 1,
      "description": "Current in-game round number"
    },
    "character_id": {
      "type": "string",
      "description": "Submitting character ID"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Submission timestamp (real-world time)"
    },
    "choice": {
      "type": "object",
      "description": "Selected choice and attitude",
      "properties": {
        "option_id": {
          "type": "string",
          "description": "ID of the selected option (from the 4 generated)"
        },
        "attitude_selections": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": {
            "type": "object",
            "properties": {
              "dimension": {
                "type": "string",
                "description": "Attitude dimension ID (e.g., caution, empathy)"
              },
              "level": {
                "type": "string",
                "description": "Selected level for this dimension"
              }
            },
            "required": ["dimension", "level"]
          },
          "description": "1-2 attitude dimension selections"
        }
      },
      "required": ["option_id", "attitude_selections"]
    },
    "equipment_change": {
      "type": "object",
      "description": "Optional: equipment swap (submitted with choice)",
      "properties": {
        "weapon": {"type": "string"},
        "armor": {"type": "string"},
        "accessory_1": {"type": "string"},
        "accessory_2": {"type": "string"}
      }
    },
    "items_used": {
      "type": "array",
      "description": "Items consumed in this round",
      "items": {
        "type": "object",
        "properties": {
          "item_id": {"type": "string"},
          "quantity": {"type": "integer", "minimum": 1}
        },
        "required": ["item_id", "quantity"]
      }
    }
  },
  "required": ["round", "character_id", "choice"]
}
