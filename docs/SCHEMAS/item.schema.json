{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw-sandbox-rpg.dev/schemas/item.json",
  "title": "Item",
  "description": "Item entity schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^item_[a-z0-9_]+$",
      "description": "Unique item ID"
    },
    "name": {
      "type": "string",
      "description": "Display name"
    },
    "type": {
      "type": "string",
      "enum": ["weapon", "armor", "consumable", "quest", "material", "tool", "decoration"]
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "maxLength": 500,
      "description": "Visual and functional description"
    },
    "interaction_patterns": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"},
      "description": "Possible interaction modes"
    },
    "rarity": {
      "type": "string",
      "enum": ["common", "uncommon", "rare", "legendary", "artifact"]
    },
    "stats_modifiers": {
      "type": "object",
      "description": "Optional: semantic state modifiers when equipped",
      "properties": {
        "stamina_resistance": {
          "type": "string",
          "description": "e.g., 'heavy_armor', 'none'"
        },
        "health_protection": {
          "type": "string"
        }
      }
    },
    "quest_item": {
      "type": "boolean",
      "default": false,
      "description": "Is this a quest-critical item?"
    },
    "disposable": {
      "type": "boolean",
      "default": false,
      "description": "Can this be consumed/destroyed?"
    },
    "narrative_tags": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Tags for narrative generation (e.g., 'cursed', 'blessed', 'ancient')"
    }
  },
  "required": ["id", "name", "type", "description", "rarity"]
}
